# Copy this file to .env and fill in your actual values.
# Restart `npm run dev` after changing .env (Vite reads env at startup).

# --- Supabase (required for the app to load) ---
# Dashboard → your project → Project Settings → API
# URL: "Project URL" | Key: "anon" / "public" (publishable key, safe in frontend)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Google OAuth Credentials
# Client ID for frontend (public - safe to expose)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Note: GOOGLE_CLIENT_SECRET should be set in:
# 1. Supabase Dashboard → Settings → Edge Functions → Secrets
# 2. Netlify/Vercel Dashboard → Environment variables (if needed)
# Never commit the secret to git or expose it in frontend code

# --- Supabase Edge Functions only (set in Dashboard → Edge Functions → Secrets, not in Vite) ---
# Public site URL for links in transactional emails (e.g. payment receipts)
# SITE_URL=https://startworking.in
#
# Hostinger SMTP for send-purchase-receipt (From support@startworking.in). If unset, falls back to RESEND_API_KEY.
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=support@startworking.in
# SMTP_PASS=your-mailbox-password
# Optional: SMTP_FROM="StartWorking <support@startworking.in>"
